{
  "crons": [
    {
      "path": "/api/scrape",
      "schedule": "30 12 * * 6"
    }
  ],
  "functions": {
    "api/scrape.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
